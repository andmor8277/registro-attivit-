<template>
  <div class="spogliatoi-page">
    <div class="print-header">
      <h1>Gestione Spogliatoi e Campi da gioco — {{ societaAttiva?.nome || '' }}</h1>
      <p v-if="tabAttivo === 'settimanale'">Settimana {{ formatDate(settimanaInizio) }} - {{ formatDate(settimanaFine) }}</p>
      <p v-else-if="weekendSelezionatoId">{{ getWeekendLabel() }}</p>
    </div>
    <header class="page-header">
      <div class="header-content">
        <button class="btn-back" @click="router.push('/responsabili')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
        </button>
        <div>
          <h1>Gestione Spogliatoi e Campi da gioco</h1>
          <p class="page-subtitle">Assegnazione settimanale e weekend</p>
        </div>
      </div>
    </header>

    <!-- Section toggle: Spogliatoi / Campi -->
    <div class="section-toggle">
      <button class="section-btn" :class="{ active: sezioneAttiva === 'spogliatoi' }" @click="sezioneAttiva = 'spogliatoi'">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        Spogliatoi
      </button>
      <button class="section-btn" :class="{ active: sezioneAttiva === 'campi' }" @click="sezioneAttiva = 'campi'">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M3 12h18M12 3v18"/>
        </svg>
        Campi da gioco
      </button>
    </div>

    <!-- Spogliatoi chips / Campi chips -->
    <div class="items-list" v-if="currentItems.length > 0">
      <div v-for="item in currentItems" :key="item.id" class="item-chip">
        <span class="chip-label">{{ item.etichetta }}</span>
        <button class="btn-icon-xs" @click="apriModal(item)" title="Modifica">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </button>
        <button class="btn-icon-xs btn-delete" @click="eliminaFn(item.id)" title="Elimina">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
          </svg>
        </button>
      </div>
    </div>

    <button class="btn-add-sm" @click="apriModal(null)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Nuovo {{ sezioneAttiva === 'spogliatoi' ? 'Spogliatoio' : 'Campo' }}
    </button>

    <div class="tabs-bar">
      <button class="tab-btn" :class="{ active: tabAttivo === 'settimanale' }" @click="tabAttivo = 'settimanale'">Settimanale</button>
      <button class="tab-btn" :class="{ active: tabAttivo === 'weekend' }" @click="tabAttivo = 'weekend'">Weekend</button>
    </div>

    <!-- SETTIMANALE TAB -->
    <div v-if="tabAttivo === 'settimanale'">
      <div class="week-selector">
        <button class="btn-nav" @click="cambiaSettimana(-1)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <span class="week-label">Settimana {{ formatDate(settimanaInizio) }} - {{ formatDate(settimanaFine) }}</span>
        <button class="btn-nav" @click="cambiaSettimana(1)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
        <button class="btn-save" @click="salvaAssegnazioniSettimana">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Salva
        </button>
        <button class="btn-save" @click="stampa">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <polyline points="6 9 6 2 18 2 18 9"/>
            <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
          </svg>
          Stampa
        </button>
      </div>

      <!-- Day tabs -->
      <div class="day-tabs" v-if="giorniSettimana.length > 0">
        <button v-for="g in giorniSettimana" :key="g.data" class="day-tab" :class="{ active: giornoAttivo === g.data, empty: g.categorie.length === 0 }" @click="selezionaGiorno(g.data)">
          <span class="day-name">{{ g.nomeBreve }}</span>
          <span class="day-date">{{ g.giorno }}</span>
          <span class="day-count" v-if="g.categorie.length > 0">{{ g.categorie.length }}</span>
        </button>
      </div>

      <div v-if="giornoAttivo && currentItems.length > 0" class="day-view">
        <div v-if="getCategorieGiorno(giornoAttivo).length === 0" class="empty-state">
          <p>Nessuna categoria si allena questo giorno</p>
        </div>
        <template v-else>
          <div v-for="(slot, ora) in categoriePerOrario(giornoAttivo)" :key="ora" class="time-slot-section">
            <div class="time-slot-header">{{ ora || 'Senza orario' }}</div>
            <div class="assegnazioni-grid" :style="{ '--cols': currentItems.length + 1 }">
              <div class="grid-header">
                <div class="grid-cell cat-header">Categoria</div>
                <div v-for="item in currentItems" :key="item.id" class="grid-cell">{{ item.etichetta }}</div>
              </div>
              <div v-for="cat in slot" :key="'s-' + cat.id" class="grid-row">
                <div class="grid-cell cat-cell">
                  <span class="cat-anno">{{ cat.anno }}</span>
                  <span class="cat-nome">{{ cat.nome }}</span>
                </div>
                <div v-for="item in currentItems" :key="item.id" class="grid-cell assignment-cell"
                     :class="{ assigned: getAssegnazioneGiorno(cat.id, item.id, giornoAttivo) }"
                     @click="toggleAssegnazioneGiorno(cat.id, item.id, giornoAttivo)">
                  <svg v-if="getAssegnazioneGiorno(cat.id, item.id, giornoAttivo)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="18" height="18">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
              </div>
              <!-- Non censite rows -->
              <div v-for="(squadra, idx) in squadreNonCensiteSettimanali" :key="'nc-s-' + idx" class="grid-row non-censite-row">
                <div class="grid-cell cat-cell non-censita-cell">
                  <span class="print-team-name">{{ squadra.nome || 'Squadra non censita' }}</span>
                  <input type="text" v-model="squadreNonCensiteSettimanali[idx].nome" placeholder="Nome squadra" class="non-censita-input" />
                  <button class="btn-rimuovi-squadra" @click.stop="rimuoviSquadraNonCensita(idx, 'settimanale')" title="Rimuovi">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                      <line x1="18" y1="6" x2="6" y2="18"/>
                      <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </button>
                </div>
                <div v-for="item in currentItems" :key="item.id" class="grid-cell assignment-cell"
                     :class="{ assigned: getAssegnazioneNonCensitaGiorno(idx, item.id, giornoAttivo) }"
                     @click="toggleAssegnazioneNonCensitaGiorno(idx, item.id, giornoAttivo)">
                  <svg v-if="getAssegnazioneNonCensitaGiorno(idx, item.id, giornoAttivo)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="18" height="18">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
              </div>
              <div class="grid-row add-row">
                <div class="grid-cell cat-cell">
                  <button class="btn-add-squadra" @click="aggiungiSquadraNonCensita('settimanale')">+ Squadra non censita</button>
                </div>
              </div>
            </div>
          </div>
        </template>
      </div>
      <div v-else-if="currentItems.length === 0" class="empty-state">
        <p>Crea almeno un {{ sezioneAttiva === 'spogliatoi' ? 'spogliatoio' : 'campo' }} per iniziare</p>
      </div>

      <!-- Print-only: all days -->
      <div class="print-all-days">
        <div v-for="g in giorniSettimana" :key="'print-' + g.data" class="print-day-section">
          <div class="print-day-header">{{ g.nomeLungo }} {{ g.giorno }} - {{ getCategorieGiorno(g.data).length }} categorie</div>
          <div v-for="(slot, ora) in categoriePerOrario(g.data)" :key="'print-slot-' + g.data + '-' + ora" class="print-slot-wrapper">
            <div class="print-time-slot">{{ ora || 'Senza orario' }}</div>
            <div class="assegnazioni-grid" :style="{ '--cols': currentItems.length + 1 }">
              <div class="grid-header">
                <div class="grid-cell cat-header">Categoria</div>
                <div v-for="item in currentItems" :key="item.id" class="grid-cell">{{ item.etichetta }}</div>
              </div>
              <div v-for="cat in slot" :key="'ps-' + cat.id" class="grid-row">
                <div class="grid-cell cat-cell">
                  <span class="cat-anno">{{ cat.anno }}</span>
                  <span class="cat-nome">{{ cat.nome }}</span>
                </div>
                <div v-for="item in currentItems" :key="item.id" class="grid-cell assignment-cell"
                     :class="{ assigned: getAssegnazioneGiorno(cat.id, item.id, g.data) }">
                  <svg v-if="getAssegnazioneGiorno(cat.id, item.id, g.data)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="18" height="18">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- WEEKEND TAB -->
    <div v-if="tabAttivo === 'weekend'">
      <div class="weekend-selector">
        <select v-model="weekendSelezionatoId" class="filter-select" @change="caricaWeekendData">
          <option :value="null">— Seleziona Weekend —</option>
          <option v-for="w in weekend" :key="w.id" :value="w.id">{{ w.nome }} ({{ formatDate(w.data_inizio) }} - {{ formatDate(w.data_fine) }})</option>
        </select>
        <button v-if="weekendSelezionatoId" class="btn-save" @click="salvaAssegnazioniWeekend">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Salva
        </button>
        <button v-if="weekendSelezionatoId" class="btn-save" @click="stampa">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <polyline points="6 9 6 2 18 2 18 9"/>
            <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
          </svg>
          Stampa
        </button>
      </div>

      <div v-if="weekendSelezionatoId" class="weekend-info">
        <div class="info-section" v-if="weekendPartite.length > 0">
          <h3>Partite programmate</h3>
          <div v-for="p in weekendPartite" :key="p.id" class="partita-info-chip">
            <span class="chip-cat">{{ getCatLabel(p.categoria_id) }}</span>
            <span class="chip-match">{{ p.avversario || 'TBD' }} {{ p.casa_fuori === 'fuori' ? '(in trasferta)' : '(in casa)' }}</span>
            <span class="chip-date">{{ formatDate(p.data_partite) }} {{ p.ora ? p.ora.slice(0,5) : '' }}</span>
          </div>
        </div>
        <div class="info-section" v-if="weekendAllenamenti.length > 0">
          <h3>Allenamenti in settimana</h3>
          <div v-for="a in weekendAllenamenti" :key="a.id" class="allenamento-info-chip">
            <span class="chip-cat">{{ getCatLabel(a.categoria_id) }}</span>
            <span class="chip-date">{{ formatDate(a.data) }}</span>
          </div>
        </div>
      </div>

      <div v-if="weekendSelezionatoId && currentItems.length > 0" class="assegnazioni-grid" :style="{ '--cols': currentItems.length + 1 }">
        <div class="grid-header">
          <div class="grid-cell cat-header">Squadra</div>
          <div v-for="item in currentItems" :key="item.id" class="grid-cell">{{ item.etichetta }}</div>
        </div>
        <div v-for="p in weekendPartiteCasa" :key="'wc-' + p.id" class="grid-row">
          <div class="grid-cell cat-cell casa-cell">
            <span class="cat-anno">{{ getCatLabel(p.categoria_id) }}</span>
            <span class="tipo-badge casa">Casa</span>
          </div>
          <div v-for="item in currentItems" :key="item.id" class="grid-cell assignment-cell"
               :class="{ assigned: getAssegnazione(p.categoria_id, item.id, 'casa', p.id) }"
               @click="toggleAssegnazione(p.categoria_id, item.id, 'casa', p.id)">
            <svg v-if="getAssegnazione(p.categoria_id, item.id, 'casa', p.id)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="18" height="18">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
        </div>
        <div v-for="p in weekendPartiteFuori" :key="'wf-' + p.id" class="grid-row">
          <div class="grid-cell cat-cell fuori-cell">
            <span class="cat-nome">{{ p.avversario || 'TBD' }}</span>
            <span class="tipo-badge fuori">Ospite</span>
          </div>
          <div v-for="item in currentItems" :key="item.id" class="grid-cell assignment-cell"
               :class="{ assigned: getAssegnazione(p.categoria_id, item.id, 'ospite', p.id) }"
               @click="toggleAssegnazione(p.categoria_id, item.id, 'ospite', p.id)">
            <svg v-if="getAssegnazione(p.categoria_id, item.id, 'ospite', p.id)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="18" height="18">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
        </div>
        <!-- Non censite rows -->
        <div v-for="(squadra, idx) in squadreNonCensiteWeekend" :key="'nc-w-' + idx" class="grid-row non-censite-row">
          <div class="grid-cell cat-cell non-censita-cell">
            <span class="print-team-name">{{ squadra.nome || 'Squadra non censita' }}</span>
            <input type="text" v-model="squadreNonCensiteWeekend[idx].nome" placeholder="Nome squadra" class="non-censita-input" />
            <button class="btn-rimuovi-squadra" @click.stop="rimuoviSquadraNonCensita(idx, 'weekend')" title="Rimuovi">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
          <div v-for="item in currentItems" :key="item.id" class="grid-cell assignment-cell"
               :class="{ assigned: getAssegnazioneNonCensita(idx, item.id, 'weekend') }"
               @click="toggleAssegnazioneNonCensita(idx, item.id, 'weekend')">
            <svg v-if="getAssegnazioneNonCensita(idx, item.id, 'weekend')" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="18" height="18">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
        </div>
        <div class="grid-row add-row">
          <div class="grid-cell cat-cell">
            <button class="btn-add-squadra" @click="aggiungiSquadraNonCensita('weekend')">+ Squadra non censita</button>
          </div>
        </div>
      </div>
      <div v-if="!weekendSelezionatoId" class="empty-state">
        <p>Seleziona un weekend per gestire gli assegnazioni</p>
      </div>
      <div v-if="weekendSelezionatoId && currentItems.length === 0" class="empty-state">
        <p>Crea almeno un {{ sezioneAttiva === 'spogliatoi' ? 'spogliatoio' : 'campo' }} per iniziare</p>
      </div>
    </div>

    <!-- Modal -->
    <Teleport to="body">
      <div v-if="modal.show" class="modal-overlay" @click.self="modal.show = false">
        <div class="modal">
          <div class="modal-header">
            <h3>{{ modal.id ? (sezioneAttiva === 'spogliatoi' ? 'Modifica Spogliatoio' : 'Modifica Campo') : (sezioneAttiva === 'spogliatoi' ? 'Nuovo Spogliatoio' : 'Nuovo Campo') }}</h3>
            <button class="modal-close" @click="modal.show = false">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
          <div class="modal-body">
            <div class="form-group">
              <label>Etichetta</label>
              <input type="text" v-model="modal.etichetta" :placeholder="sezioneAttiva === 'spogliatoi' ? 'Es. Spogliatoio A, Casa 1, Ospiti...' : 'Es. Campo principale, Campo B...'" />
            </div>
            <div class="form-group">
              <label>Ordine</label>
              <input type="number" v-model.number="modal.ordine" min="0" />
            </div>
          </div>
          <div class="modal-footer">
            <button class="btn-secondary" @click="modal.show = false">Annulla</button>
            <button class="btn-primary" @click="salvaModal">{{ modal.id ? 'Salva' : 'Crea' }}</button>
          </div>
        </div>
      </div>
    </Teleport>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, watch } from "vue"
import { useRouter } from "vue-router"
import { useStore } from "../store.js"
import {
  getAllCategorie,
  getSpogliatoi,
  creaSpogliatoio,
  aggiornaSpogliatoio,
  eliminaSpogliatoio,
  getAssegnazioniSettimana,
  getAssegnazioniWeekend,
  creaAssegnazione,
  aggiornaAssegnazione,
  eliminaAssegnazione,
  getWeekend,
  getCampi,
  creaCampo,
  aggiornaCampo,
  eliminaCampo,
  getCampiAssegnazioniSettimana,
  getCampiAssegnazioniWeekend,
  creaCampoAssegnazione,
  aggiornaCampoAssegnazione
} from "../api/index.js"

const router = useRouter()
const { societaAttiva } = useStore()

const sezioneAttiva = ref('spogliatoi')
const tabAttivo = ref('settimanale')
const spogliatoi = ref([])
const campi = ref([])
const categorie = ref([])
const weekend = ref([])
const weekendSelezionatoId = ref(null)
const weekendPartite = ref([])
const weekendAllenamenti = ref([])

const settimanaInizio = ref(getLunesdiCorrente())
const giornoAttivo = ref(null)
const assegnazioniSettimanali = ref({})
const squadreNonCensiteSettimanali = ref([])

const assegnazioniWeekend = ref({})
const squadreNonCensiteWeekend = ref([])

const modal = ref({ show: false, id: null, etichetta: '', ordine: 0 })

const currentItems = computed(() => sezioneAttiva.value === 'spogliatoi' ? spogliatoi.value : campi.value)

const currentItemIdKey = computed(() => sezioneAttiva.value === 'spogliatoi' ? 'spogliatoio_id' : 'campo_id')

const categorieOrdinate = computed(() =>
  categorie.value.sort((a, b) => (a.anno || 9999) - (b.anno || 9999))
)

const giorniSettimana = computed(() => {
  const giorni = []
  const nomi = ['Lun', 'Mar', 'Mer', 'Gio', 'Ven']
  const nomiLunghi = ['Lunedì', 'Martedì', 'Mercoledì', 'Giovedì', 'Venerdì']
  const d = new Date(settimanaInizio.value)
  for (let i = 0; i < 5; i++) {
    const dataStr = d.toISOString().split('T')[0]
    const dow = d.getDay()
    const cats = getCategoriePerGiornoSettimana(dow)
    giorni.push({
      data: dataStr,
      nomeBreve: nomi[i],
      nomeLungo: nomiLunghi[i],
      giorno: d.getDate(),
      categorie: cats
    })
    d.setDate(d.getDate() + 1)
  }
  return giorni
})

function getCategoriePerGiornoSettimana(dow) {
  return categorie.value.filter(c => {
    if (!c.giorni) return false
    return c.giorni.split(',').map(Number).includes(dow)
  })
}

function getCategorieGiorno(dataGiorno) {
  const d = new Date(dataGiorno)
  const dow = d.getDay()
  return getCategoriePerGiornoSettimana(dow)
}

function categoriePerOrario(dataGiorno) {
  const cats = getCategorieGiorno(dataGiorno)
  const grouped = {}
  cats.forEach(c => {
    const ora = c.ora_allenamento || 'Senza orario'
    if (!grouped[ora]) grouped[ora] = []
    grouped[ora].push(c)
  })
  const sorted = Object.entries(grouped).sort((a, b) => a[0].localeCompare(b[0]))
  const result = {}
  sorted.forEach(([ora, cats]) => {
    result[ora] = cats.sort((a, b) => (a.anno || 9999) - (b.anno || 9999))
  })
  return result
}

function selezionaGiorno(data) {
  giornoAttivo.value = data
}

const settimanaFine = computed(() => {
  const d = new Date(settimanaInizio.value)
  d.setDate(d.getDate() + 4)
  return d.toISOString().split('T')[0]
})

const weekendPartiteCasa = computed(() =>
  weekendPartite.value.filter(p => p.casa_fuori !== 'fuori')
)

const weekendPartiteFuori = computed(() =>
  weekendPartite.value.filter(p => p.casa_fuori === 'fuori')
)

function getLunesdiCorrente() {
  const oggi = new Date()
  const giorno = oggi.getDay()
  const diff = giorno === 0 ? -6 : 1 - giorno
  const lunedi = new Date(oggi)
  lunedi.setDate(oggi.getDate() + diff)
  return lunedi.toISOString().split('T')[0]
}

function getWeekendLabel() {
  const w = weekend.value.find(w => w.id === weekendSelezionatoId.value)
  return w ? `Weekend: ${w.nome} (${formatDate(w.data_inizio)} - ${formatDate(w.data_fine)})` : ''
}

function formatDate(dateStr) {
  if (!dateStr) return ''
  const [y, m, d] = dateStr.split('-')
  return `${d}/${m}/${y}`
}

function getCatLabel(catId) {
  const cat = categorie.value.find(c => c.id === catId)
  return cat ? `${cat.anno} - ${cat.nome}` : 'N/D'
}

function cambiaSettimana(delta) {
  const d = new Date(settimanaInizio.value)
  d.setDate(d.getDate() + delta * 7)
  settimanaInizio.value = d.toISOString().split('T')[0]
  caricaAssegnazioniSettimana()
}

// ── Assignment helpers (generic over current section) ──

function getAssegnazione(catId, itemId, tipo, partitaId) {
  if (tabAttivo.value === 'settimanale') {
    const key = `${catId}_${itemId}`
    return assegnazioniSettimanali.value[key] !== undefined
  } else {
    const key = `${tipo}_${partitaId || ''}_${itemId}`
    return assegnazioniWeekend.value[key] !== undefined
  }
}

function getAssegnazioneNonCensita(idx, itemId, contesto) {
  if (contesto === 'settimanale') {
    const key = `noncensita_${idx}_${itemId}`
    return assegnazioniSettimanali.value[key] !== undefined
  } else {
    const key = `noncensita_weekend_${idx}_${itemId}`
    return assegnazioniWeekend.value[key] !== undefined
  }
}

function getAssegnazioneGiorno(catId, itemId, dataGiorno) {
  const key = `${catId}_${itemId}_${dataGiorno}`
  return assegnazioniSettimanali.value[key] !== undefined
}

function getAssegnazioneNonCensitaGiorno(idx, itemId, dataGiorno) {
  const key = `noncensita_${idx}_${itemId}_${dataGiorno}`
  return assegnazioniSettimanali.value[key] !== undefined
}

function toggleAssegnazioneGiorno(catId, itemId, dataGiorno) {
  const key = `${catId}_${itemId}_${dataGiorno}`
  const idKey = currentItemIdKey.value
  if (assegnazioniSettimanali.value[key]) {
    delete assegnazioniSettimanali.value[key]
  } else {
    assegnazioniSettimanali.value[key] = { categoria_id: catId, [idKey]: itemId, data: dataGiorno }
  }
}

function toggleAssegnazioneNonCensitaGiorno(idx, itemId, dataGiorno) {
  const key = `noncensita_${idx}_${itemId}_${dataGiorno}`
  const idKey = currentItemIdKey.value
  const squadra = squadreNonCensiteSettimanali.value[idx]
  if (assegnazioniSettimanali.value[key]) {
    delete assegnazioniSettimanali.value[key]
  } else {
    assegnazioniSettimanali.value[key] = {
      [idKey]: itemId,
      nome_squadra_esterna: squadra.nome,
      tipo: 'esterna',
      data: dataGiorno
    }
  }
}

function toggleAssegnazione(catId, itemId, tipo, partitaId) {
  if (tabAttivo.value === 'settimanale') {
    const key = `${catId}_${itemId}`
    const idKey = currentItemIdKey.value
    if (assegnazioniSettimanali.value[key]) {
      delete assegnazioniSettimanali.value[key]
    } else {
      assegnazioniSettimanali.value[key] = { categoria_id: catId, [idKey]: itemId }
    }
  } else {
    const key = `${tipo}_${partitaId || ''}_${itemId}`
    const idKey = currentItemIdKey.value
    if (assegnazioniWeekend.value[key]) {
      delete assegnazioniWeekend.value[key]
    } else {
      assegnazioniWeekend.value[key] = {
        categoria_id: catId,
        [idKey]: itemId,
        tipo: tipo,
        partita_id: partitaId
      }
    }
  }
}

function toggleAssegnazioneNonCensita(idx, itemId, contesto) {
  const idKey = currentItemIdKey.value
  if (contesto === 'settimanale') {
    const key = `noncensita_${idx}_${itemId}`
    const squadra = squadreNonCensiteSettimanali.value[idx]
    if (assegnazioniSettimanali.value[key]) {
      delete assegnazioniSettimanali.value[key]
    } else {
      assegnazioniSettimanali.value[key] = {
        [idKey]: itemId,
        nome_squadra_esterna: squadra.nome,
        tipo: 'esterna'
      }
    }
  } else {
    const key = `noncensita_weekend_${idx}_${itemId}`
    const squadra = squadreNonCensiteWeekend.value[idx]
    if (assegnazioniWeekend.value[key]) {
      delete assegnazioniWeekend.value[key]
    } else {
      assegnazioniWeekend.value[key] = {
        [idKey]: itemId,
        nome_squadra_esterna: squadra.nome,
        tipo: 'esterna'
      }
    }
  }
}

function aggiungiSquadraNonCensita(contesto) {
  if (contesto === 'settimanale') {
    squadreNonCensiteSettimanali.value.push({ nome: '' })
  } else {
    squadreNonCensiteWeekend.value.push({ nome: '' })
  }
}

function rimuoviSquadraNonCensita(idx, contesto) {
  if (contesto === 'settimanale') {
    squadreNonCensiteSettimanali.value.splice(idx, 1)
    const keys = Object.keys(assegnazioniSettimanali.value)
    keys.forEach(k => {
      if (k.startsWith(`noncensita_${idx}_`)) delete assegnazioniSettimanali.value[k]
    })
  } else {
    squadreNonCensiteWeekend.value.splice(idx, 1)
    const keys = Object.keys(assegnazioniWeekend.value)
    keys.forEach(k => {
      if (k.startsWith(`noncensita_weekend_${idx}_`)) delete assegnazioniWeekend.value[k]
    })
  }
}

// ── Load data ──

async function loadSpogliatoi() {
  try {
    const res = await getSpogliatoi(societaAttiva.value?.id || null)
    spogliatoi.value = res.data || []
  } catch (e) {
    console.error('Errore caricamento spogliatoi:', e)
  }
}

async function loadCampi() {
  try {
    const res = await getCampi(societaAttiva.value?.id || null)
    campi.value = res.data || []
  } catch (e) {
    console.error('Errore caricamento campi:', e)
  }
}

async function loadCategorie() {
  try {
    const res = await getAllCategorie(societaAttiva.value?.id || null)
    categorie.value = res.data || []
  } catch (e) {
    console.error('Errore caricamento categorie:', e)
  }
}

async function loadWeekend() {
  try {
    const res = await getWeekend(societaAttiva.value?.id || null)
    weekend.value = res.data || []
  } catch (e) {
    console.error('Errore caricamento weekend:', e)
  }
}

async function caricaAssegnazioniSettimana() {
  assegnazioniSettimanali.value = {}
  squadreNonCensiteSettimanali.value = []
  try {
    const apiFn = sezioneAttiva.value === 'spogliatoi' ? getAssegnazioniSettimana : getCampiAssegnazioniSettimana
    const res = await apiFn(settimanaInizio.value)
    const data = res.data || []
    const idKey = currentItemIdKey.value
    const nomiUnici = new Set()
    data.forEach(a => {
      if (a.categoria_id) {
        const dataKey = a.data || settimanaInizio.value
        assegnazioniSettimanali.value[`${a.categoria_id}_${a[idKey]}_${dataKey}`] = a
      } else if (a.nome_squadra_esterna) {
        if (!nomiUnici.has(a.nome_squadra_esterna)) {
          nomiUnici.add(a.nome_squadra_esterna)
          squadreNonCensiteSettimanali.value.push({ nome: a.nome_squadra_esterna })
        }
      }
    })
    squadreNonCensiteSettimanali.value.forEach((squadra, idx) => {
      data.forEach(a => {
        if (a.nome_squadra_esterna === squadra.nome) {
          const dataKey = a.data || settimanaInizio.value
          assegnazioniSettimanali.value[`noncensita_${idx}_${a[idKey]}_${dataKey}`] = a
        }
      })
    })
    if (giorniSettimana.value.length > 0) {
      const firstDay = giorniSettimana.value.find(g => g.categorie.length > 0)
      if (firstDay) {
        giornoAttivo.value = firstDay.data
      } else {
        giornoAttivo.value = giorniSettimana.value[0].data
      }
    }
  } catch (e) {
    console.error('Errore caricamento assegnazioni settimanali:', e)
  }
}

async function caricaWeekendData() {
  assegnazioniWeekend.value = {}
  weekendPartite.value = []
  weekendAllenamenti.value = []
  squadreNonCensiteWeekend.value = []
  if (!weekendSelezionatoId.value) return

  try {
    const apiFn = sezioneAttiva.value === 'spogliatoi' ? getAssegnazioniWeekend : getCampiAssegnazioniWeekend
    const [asgnRes] = await Promise.all([
      apiFn(weekendSelezionatoId.value)
    ])
    const asgnData = asgnRes.data || []
    const idKey = currentItemIdKey.value
    const nomiUnici = new Set()
    asgnData.forEach(a => {
      if (a.categoria_id && a.tipo === 'ospite') {
        assegnazioniWeekend.value[`ospite_${a.partita_id || ''}_${a[idKey]}`] = a
      } else if (a.categoria_id) {
        assegnazioniWeekend.value[`casa_${a.partita_id || ''}_${a[idKey]}`] = a
      } else if (a.nome_squadra_esterna) {
        if (!nomiUnici.has(a.nome_squadra_esterna)) {
          nomiUnici.add(a.nome_squadra_esterna)
          squadreNonCensiteWeekend.value.push({ nome: a.nome_squadra_esterna })
        }
      }
    })
    squadreNonCensiteWeekend.value.forEach((squadra, idx) => {
      asgnData.forEach(a => {
        if (a.nome_squadra_esterna === squadra.nome) {
          assegnazioniWeekend.value[`noncensita_weekend_${idx}_${a[idKey]}`] = a
        }
      })
    })
  } catch (e) {
    console.error('Errore caricamento assegnazioni weekend:', e)
  }

  try {
    const { getWeekendPartite } = await import('../api/index.js')
    const res = await getWeekendPartite(weekendSelezionatoId.value)
    weekendPartite.value = res.data || []
  } catch (e) {
    console.error('Errore caricamento partite weekend:', e)
  }
}

// ── Save ──

async function salvaAssegnazioniSettimana() {
  const entries = Object.entries(assegnazioniSettimanali.value)
  const apiFn = sezioneAttiva.value === 'spogliatoi' ? creaAssegnazione : creaCampoAssegnazione
  const updFn = sezioneAttiva.value === 'spogliatoi' ? aggiornaAssegnazione : aggiornaCampoAssegnazione
  for (const [, val] of entries) {
    const payload = {
      ...val,
      data_inizio: settimanaInizio.value,
      societa_id: societaAttiva.value?.id || null
    }
    if (val.id) {
      await updFn(val.id, payload)
    } else {
      const res = await apiFn(payload)
      assegnazioniSettimanali.value[Object.keys(assegnazioniSettimanali.value).find(k => assegnazioniSettimanali.value[k] === val)] = res.data
    }
  }
  alert('Assegnazioni settimanali salvate!')
}

async function salvaAssegnazioniWeekend() {
  const entries = Object.entries(assegnazioniWeekend.value)
  const apiFn = sezioneAttiva.value === 'spogliatoi' ? creaAssegnazione : creaCampoAssegnazione
  const updFn = sezioneAttiva.value === 'spogliatoi' ? aggiornaAssegnazione : aggiornaCampoAssegnazione
  for (const [, val] of entries) {
    const payload = {
      ...val,
      weekend_id: weekendSelezionatoId.value,
      societa_id: societaAttiva.value?.id || null
    }
    if (val.id) {
      await updFn(val.id, payload)
    } else {
      const res = await apiFn(payload)
      assegnazioniWeekend.value[Object.keys(assegnazioniWeekend.value).find(k => assegnazioniWeekend.value[k] === val)] = res.data
    }
  }
  alert('Assegnazioni weekend salvate!')
}

// ── Modal CRUD ──

function apriModal(item) {
  if (item) {
    modal.value = { show: true, id: item.id, etichetta: item.etichetta, ordine: item.ordine || 0 }
  } else {
    const list = currentItems.value
    modal.value = { show: true, id: null, etichetta: '', ordine: list.length }
  }
}

async function salvaModal() {
  const payload = { ...modal.value, societa_id: societaAttiva.value?.id || null }
  if (sezioneAttiva.value === 'spogliatoi') {
    if (modal.value.id) {
      await aggiornaSpogliatoio(modal.value.id, payload)
    } else {
      await creaSpogliatoio(payload)
    }
    await loadSpogliatoi()
  } else {
    if (modal.value.id) {
      await aggiornaCampo(modal.value.id, payload)
    } else {
      await creaCampo(payload)
    }
    await loadCampi()
  }
  modal.value.show = false
}

async function eliminaFn(id) {
  if (!confirm('Eliminare questo elemento e le sue assegnazioni?')) return
  if (sezioneAttiva.value === 'spogliatoi') {
    await eliminaSpogliatoio(id)
    await loadSpogliatoi()
  } else {
    await eliminaCampo(id)
    await loadCampi()
  }
}

function stampa() {
  window.print()
}

// ── Watch section change ──

watch(sezioneAttiva, () => {
  if (tabAttivo.value === 'settimanale') {
    caricaAssegnazioniSettimana()
  } else if (weekendSelezionatoId.value) {
    caricaWeekendData()
  }
})

onMounted(() => {
  loadSpogliatoi()
  loadCampi()
  loadCategorie()
  loadWeekend()
  caricaAssegnazioniSettimana()
})
</script>

